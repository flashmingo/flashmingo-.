# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Site ────────────────────────────────────────────────────────────────────
# Production: https://yourdomain.com — used for metadata, sitemap, OG images
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI deck generation ──────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key

# ── Demo request notifications (optional) ───────────────────────────────────
# When both are set, demo form submissions email the team via Resend.
# Leads are always stored in the demo_requests table regardless.
RESEND_API_KEY=
DEMO_NOTIFY_EMAIL=
# Optional custom sender, e.g. "FlashMingo <demos@yourdomain.com>"
DEMO_FROM_EMAIL=
